<% if user_signed_in? %>
  <% if racket.like_by?(current_user) %>
	  <%= link_to racket_like_path(racket, racket.likes), data: { turbo_method: :delete } do %>
		  <%= image_tag "heart_fil.svg", class: 'size-6 md:size-7 ml-1' %>
		<% end %>
  <% else %>
		<%= link_to racket_likes_path(racket), data{ turbo_method: :post } do %>
		  <%= image_tag "heart.svg", class: 'size-6 md:size-7 ml-1' %>
		<% end %>
  <% end %>
	<%= racket.likes.count class: 'text-[9px] text-col-navy' %>
<% end %>

