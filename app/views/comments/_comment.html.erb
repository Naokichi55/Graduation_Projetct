<!-- data-user-id属性を追加して、コメント投稿のIDを埋め込む -->
<div id="comment-<%= comment.id %>" data-user-id="<%= comment.user_id %>">
  <div>
  <!-- 本リリース時にuserのアイコンを表示できるように実装 -->
	  <div class="bg-orange-700  text-white my-2 rounded-md ">
		  <div>
		    <%= comment.user.name %>
		  </div>
			<div>
		    <%= simple_format(comment.body)%>
			</div>
      <% if current_user.own?(comment) %>
        <!-- 編集機能は本リリース時に実装" -->
			  <div class="text-end">
				  <!-- コメント削除ができないようにlink_toを変更 ->
			    <% link_to"削除", comment_path(comment), class: "text-white bg-red rounded-md pt-2 pb-1 pl-2 pr-1" ,data: { turbo: false, comment_id: comment.id, confirm: '削除しますか？' } %> <!-- `turbo_method: :delete, turbo_confirm: '削除しますか?`をturboを無効化する内容に変更" comment_idを定義 -->
		    </div>
	    <% end %>
	  </div>
  </div>
</div>
